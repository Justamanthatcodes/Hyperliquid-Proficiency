from hyperliquid.info import Info
from hyperliquid.utils import constants
#Using hyperliquid official library 
#Use this to connect to hyperliquid website, constants so no matter what website name is it will work
info = Info(constants.MAINNET_API_URL, skip_ws=True)
all_mids = info.all_mids()

if "BTC" in all_mids:
    live_price = float(all_mids["BTC"])

print(f"Live price of bitcoin is ${live_price}")
